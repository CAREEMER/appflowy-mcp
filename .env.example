# ---- AppFlowy backend (service account) ----
APPFLOWY_BASE_URL=https://appflowy.example.com
APPFLOWY_EMAIL=service@example.com
APPFLOWY_PASSWORD=change-me
# Or use a pre-minted JWT instead of email/password (takes precedence):
# APPFLOWY_ACCESS_TOKEN=eyJ...

# ---- MCP server ----
APPFLOWY_MCP_HOST=0.0.0.0
APPFLOWY_MCP_PORT=8000
APPFLOWY_MCP_PATH=/mcp
APPFLOWY_MCP_REQUIRE_AUTH=true
# APPFLOWY_MCP_LOG_LEVEL=INFO
# APPFLOWY_MCP_FOLDER_CACHE_TTL=15

# ---- Client tokens + scopes ----
# A scope is "WORKSPACE_ID", "WORKSPACE_ID/VIEW_ID", or a deeper path; the last
# id is the root of the allowed subtree. Empty scopes => all workspaces.
#
# JSON form (one secret holds everything):
APPFLOWY_MCP_TOKENS=[{"token":"sk-full","name":"full","scopes":[]},{"token":"sk-project","name":"project","scopes":["WORKSPACE_ID/ROOT_VIEW_ID"]}]
#
# Indexed form (alternative; do not mix duplicate tokens):
# APPFLOWY_MCP_TOKEN_0=sk-full
# APPFLOWY_MCP_TOKEN_0_NAME=full
# APPFLOWY_MCP_TOKEN_0_SCOPES=
# APPFLOWY_MCP_TOKEN_1=sk-project
# APPFLOWY_MCP_TOKEN_1_NAME=project
# APPFLOWY_MCP_TOKEN_1_SCOPES=WORKSPACE_ID/ROOT_VIEW_ID,WORKSPACE_ID/A/B/DEEP_VIEW_ID
